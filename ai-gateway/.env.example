# ai-gateway — переменные окружения.
# Скопируйте этот файл в .env и заполните ключами: `cp .env.example .env`.
# .env добавлен в .gitignore — ключи никогда не коммитятся в репозиторий.

# --- Сервис ---
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=info
# Через запятую; пусто = CORS выключен (безопасный вариант по умолчанию).
# В проде браузер вообще не должен ходить сюда напрямую — он ходит в
# nexd, а nexd проксирует в ai-gateway по внутренней docker-сети (см.
# NEX_AI_GATEWAY_SECRET ниже). CORS_ORIGINS нужен только для локальной
# разработки без nexd-прокси (фронт на Vite напрямую бьёт в ai-gateway).
# CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=

# Секрет, общий с Go-бэкендом nexd — ОДНО И ТО ЖЕ значение задаётся тут
# и в NEX_AI_GATEWAY_SECRET на стороне nexd (см. .env.example в корне
# репозитория / deploy/.env.example). Пока пусто — секрет не проверяется,
# X-Tenant-Id читается как есть (годится для локальной разработки без
# nexd рядом). В проде ОБЯЗАТЕЛЬНО задайте — иначе любой, кто достучится
# до ai-gateway, может вписать в X-Tenant-Id чужого тенанта и обойти его
# бюджет. Сгенерировать: `openssl rand -base64 32`.
NEX_AI_GATEWAY_SECRET=

# --- Какой провайдер использовать, если клиент явно не указал ---
# gemini | custom | openai | deepseek | qwen | kimi | gigachat | yandexgpt
DEFAULT_PROVIDER=gemini

# --- Fallback-цепочка между провайдерами (см. app/services/ai_service.py) ---
# Через запятую, по приоритету. Работает только когда клиент САМ не указал
# provider в запросе — явный выбор провайдера (например, ru-restricted
# маршрут для ПДн) всегда уважается буквально, без автопереключения.
# Провайдеры без настроенного ключа молча пропускаются (не ломает старт
# сервиса с частично заполненным .env). DEFAULT_PROVIDER всегда достижим,
# даже если забыт в этом списке — см. app/main.py:_build_service.
PROVIDER_FALLBACK_CHAIN=deepseek,kimi,gemini

# Провайдер регистрируется, только если для него задан ключ (или включён
# мок-режим для gigachat/yandexgpt) — можно настроить один, несколько или
# все сразу, сервис стартует с любым непустым набором.

# --- Gemini (https://ai.google.dev/) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- custom: свободный слот под любой другой OpenAI-совместимый /chat/completions ---
CUSTOM_API_KEY=
CUSTOM_BASE_URL=https://llm-api.fun/v1
CUSTOM_MODEL=agent

# --- OpenAI (https://platform.openai.com/) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- DeepSeek (https://platform.deepseek.com/) — OpenAI-совместимый ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Qwen / Alibaba DashScope compatible-mode (https://dashscope.aliyun.com/) ---
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Kimi / Moonshot (https://platform.moonshot.cn/) — OpenAI-совместимый ---
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# --- GigaChat (Сбер, https://developers.sber.ru/docs/ru/gigachat/api/overview) ---
# СВОЙ контракт: OAuth2 client credentials + сертификаты НУЦ Минцифры РФ.
# GIGACHAT_AUTH_KEY — это готовый "Ключ авторизации" (Authorization key)
# из личного кабинета GigaChat API, НЕ client_id/client_secret по отдельности.
GIGACHAT_AUTH_KEY=
# GIGACHAT_API_PERS (физлицо) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat
# Путь к PEM с корневым сертификатом НУЦ Минцифры (нужен для TLS) —
# см. https://developers.sber.ru/docs/ru/gigachat/certificates
GIGACHAT_CA_BUNDLE=
# true — отключить проверку TLS-сертификата. Только для дев-стенда без
# бандла сертификата, НИКОГДА не включайте в проде.
GIGACHAT_INSECURE_SKIP_VERIFY=false
# true — не ходить в реальный GigaChat, отвечать детерминированной
# заглушкой (см. app/providers/gigachat.py). Полезно для дев-режима без
# настоящих credentials Сбера — так и было в этой среде разработки.
GIGACHAT_MOCK=false

# --- YandexGPT / Yandex Cloud Foundation Models ---
# https://yandex.cloud/ru/docs/foundation-models/quickstart/yandexgpt
# СВОЙ контракт: Api-Key сервисного аккаунта + folder_id (не IAM-токен —
# он короткоживущий и требует отдельного цикла обновления, см. пояснение
# в app/providers/yandexgpt.py).
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=
YANDEXGPT_BASE_URL=https://llm.api.cloud.yandex.net
YANDEXGPT_MODEL=yandexgpt-lite
# Аналогично GIGACHAT_MOCK — заглушка без реального Api-Key/folder_id.
YANDEXGPT_MOCK=false

# --- Безопасность и оптимизация ---
REQUEST_TIMEOUT_SECONDS=40
MAX_OUTPUT_TOKENS=2048
RATE_LIMIT_PER_MINUTE=20

# --- Кэш ответов LLM (provider, tenant, system, messages) → ответ ---
# См. app/core/response_cache.py. Изолирован по тенантам — один тенант
# никогда не получит ответ, закэшированный для промпта другого. Кэш-хит
# не тратит бюджет тенанта (реального обращения к провайдеру не было).
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_TTL_SECONDS=300
RESPONSE_CACHE_MAX_ENTRIES=1000

# --- Бюджеты по тенантам (per-tenant budgets) ---
# Тенант определяется заголовком X-Tenant-Id в запросе; если клиент его
# не передал — используется тенант "default" (у него тоже есть бюджет).
# Когда задан NEX_AI_GATEWAY_SECRET, этот заголовок доверенный: его
# подставляет только nexd из настоящей сессии, а не браузер напрямую.
#
# Персональные лимиты по тенантам — отдельным JSON-файлом (не через
# env: неудобно перечислять много тенантов переменными окружения).
# Пример формата — tenants.example.json; скопируйте в tenants.json и
# отредактируйте: `cp tenants.example.json tenants.json`.
TENANT_BUDGETS_FILE=tenants.json

# Лимит по умолчанию — для любого тенанта, которого нет в
# TENANT_BUDGETS_FILE (в том числе для "default", если не переопределён
# в файле). Эти четыре поля всегда числа (нельзя задать "без
# ограничения" через .env) — если нужно не ограничивать тенанта по
# какому-то измерению, задайте очень большое число либо пропишите его
# персонально в tenants.json с нужным полем без ограничения (null).
BUDGET_DEFAULT_DAILY_TOKENS=20000
BUDGET_DEFAULT_DAILY_COST_USD=1.0
BUDGET_DEFAULT_MONTHLY_TOKENS=400000
BUDGET_DEFAULT_MONTHLY_COST_USD=20.0

# Цена за 1000 токенов ($) — нужна только для лимитов по деньгам
# (daily/monthly_cost_usd). Оставьте 0, если хотите ограничивать бюджет
# только по числу токенов, без оценки стоимости в валюте.
#
# Дефолты ниже (см. app/config.py) — публичные прайс-листы провайдеров
# по состоянию на июль 2026, пересчитанные в $/1000 токенов (рублёвые
# тарифы GigaChat/YandexGPT — по курсу ЦБ РФ ≈78₽/$). Это ОРИЕНТИР, не
# прайс-лист для реального биллинга — провайдеры меняют цены без
# предупреждения; таблица с источниками — ai-gateway/README.md,
# раздел «Цены за токен». Уже подставленные значения ниже — те же
# самые дефолты, что и в коде: этот файл не обязателен, чтобы получить
# рабочие денежные лимиты, но перечислен явно для наглядности и чтобы
# было куда вписать актуальную цену, если старая устареет.
GEMINI_PRICE_INPUT_PER_1K_USD=0.00015
GEMINI_PRICE_OUTPUT_PER_1K_USD=0.00125
CUSTOM_PRICE_INPUT_PER_1K_USD=0.0
CUSTOM_PRICE_OUTPUT_PER_1K_USD=0.0
OPENAI_PRICE_INPUT_PER_1K_USD=0.00015
OPENAI_PRICE_OUTPUT_PER_1K_USD=0.0006
DEEPSEEK_PRICE_INPUT_PER_1K_USD=0.00014
DEEPSEEK_PRICE_OUTPUT_PER_1K_USD=0.00028
QWEN_PRICE_INPUT_PER_1K_USD=0.0004
QWEN_PRICE_OUTPUT_PER_1K_USD=0.0012
KIMI_PRICE_INPUT_PER_1K_USD=0.0002
KIMI_PRICE_OUTPUT_PER_1K_USD=0.002
GIGACHAT_PRICE_INPUT_PER_1K_USD=0.00256
GIGACHAT_PRICE_OUTPUT_PER_1K_USD=0.00256
YANDEXGPT_PRICE_INPUT_PER_1K_USD=0.00256
YANDEXGPT_PRICE_OUTPUT_PER_1K_USD=0.00513
