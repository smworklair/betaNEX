# Конфигурация nexd для локальной разработки.
# Скопируйте в .env (он в .gitignore) и поправьте при необходимости.
# Все переменные опциональны — значения по умолчанию см. README.md.

NEX_ENV=development
NEX_HTTP_ADDR=:8080
NEX_LOG_LEVEL=debug
NEX_LOG_FORMAT=text

# Подключение к Postgres из compose.yaml (веха M1).
NEX_DATABASE_URL=postgres://nex:nex@localhost:5432/nex?sslmode=disable

# Время жизни сессии (cookie nex_session).
NEX_SESSION_TTL=24h

# Файловое хранилище (сканы документов): каталог и лимит загрузки.
NEX_DATA_DIR=./data
NEX_MAX_UPLOAD_BYTES=20971520

# Прокси к ai-gateway (см. ai-gateway/README.md, internal/platform/httpapi/
# aiproxy.go). Пусто в URL — прокси не монтируется, ИИ-эндпоинты /api/v1/ai/*
# просто не появляются (демо-режим фронтенда). Локально ai-gateway обычно
# поднят на :8090 (см. ai-gateway/README.md) — то же значение задайте в
# NEX_AI_GATEWAY_SECRET и в ai-gateway/.env как NEX_AI_GATEWAY_SECRET, ЕСЛИ
# вообще хотите проверять секрет локально; для локальной разработки можно
# оставить пустым (тогда обе стороны просто не проверяют секрет).
# NEX_AI_GATEWAY_URL=http://localhost:8090
# NEX_AI_GATEWAY_SECRET=
