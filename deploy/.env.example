# Секреты прод-стека NEX. Скопируйте рядом: `cp .env.example .env`
# (deploy/.env в .gitignore — никогда не коммитится).
#
# Docker compose подставляет эти переменные и в compose.prod.yaml
# (через ${VAR}), и в контейнеры caddy/nexd/ai-gateway (через env_file).

# --- Домен и TLS ---
# Реальный домен, на который смотрит DNS этого сервера — Caddy получит
# для него TLS-сертификат Let's Encrypt автоматически. Порты 80/443
# должны быть доступны из интернета (для HTTP-01 challenge).
NEX_DOMAIN=nex.example.com

# --- Postgres ---
POSTGRES_PASSWORD=change-me-to-a-real-secret

# --- nexd (Go-бэкенд) ---
NEX_DATABASE_URL=postgres://nex:change-me-to-a-real-secret@postgres:5432/nex?sslmode=disable
# Разрешить фронтенду (тот же origin через Caddy — см. Caddyfile) ходить
# без дополнительного CORS: обычно НЕ нужно задавать вообще, оставьте
# пустым, если фронтенд и API — один и тот же домен (стандартный случай
# этого прод-стека).
NEX_CORS_ORIGINS=

# --- ai-gateway: хотя бы один провайдер (см. ai-gateway/.env.example
# для полного списка переменных — GigaChat/YandexGPT/DeepSeek/Qwen/Kimi/...) ---
GEMINI_API_KEY=
CUSTOM_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
GIGACHAT_AUTH_KEY=
GIGACHAT_MOCK=false
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=
YANDEXGPT_MOCK=false
DEFAULT_PROVIDER=gemini
