# Nex-pilot — переменные окружения.
# Скопируйте в .env: `cp .env.example .env` (для CLI необязательно —
# все переменные имеют разумные значения по умолчанию, см. nexpilot/config.py).

# --- Какой backend использовать ---
# frankai (по умолчанию, локально, без сети и ключей) | gateway (через ai-gateway)
NEXPILOT_BACKEND=frankai

# --- FrankAI ---
# Пути по умолчанию указывают на ../FrankAI относительно этой папки —
# переопределяйте только если разложили проекты по-другому.
# FRANKAI_WEIGHTS_PATH=../FrankAI/weights/frankai_weights.npz
# FRANKAI_CORPUS_PATH=../FrankAI/frankai/data/sample_corpus.txt
FRANKAI_MAX_NEW_TOKENS=200

# --- ai-gateway (только если NEXPILOT_BACKEND=gateway) ---
# Сервис должен быть запущен отдельно, см. ../../ai-gateway/README.md.
AI_GATEWAY_URL=http://localhost:8090
# AI_GATEWAY_TENANT_ID=demo-tenant
# Общий секрет с ai-gateway (то же значение, что и NEX_AI_GATEWAY_SECRET
# в ai-gateway/.env) — нужен, только если на стороне ai-gateway секрет
# вообще настроен. Nex-pilot ходит в ai-gateway напрямую, минуя nexd
# (см. nexpilot/backends/gateway_backend.py), поэтому подписывает
# запрос сам, тем же способом, что и nexd.
# AI_GATEWAY_SECRET=
# Какой провайдер ai-gateway использовать — пусто значит "пусть шлюз
# выберет сам" (DEFAULT_PROVIDER / цепочка fallback на его стороне).
# gemini | custom | openai | deepseek | qwen | kimi | gigachat | yandexgpt
# AI_GATEWAY_PROVIDER=
